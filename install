#!/usr/bin/env bash
# install — lifecycle hook run by `voodu plugins:install caddy`.
#
# Responsibilities:
#   1. Download the voodu-caddy plugin binary into $VOODU_PLUGIN_DIR/bin/voodu-caddy
#   2. Ensure the `voodu0` docker network exists (shared with apps)
#   3. Run official Caddy image as container `voodu-caddy` on voodu0,
#      publishing :80/:443 (ingress) and 127.0.0.1:2019 (Admin API)
#   4. Seed an empty bootstrap config so Caddy starts on a fresh machine
#
# Idempotent: safe to run repeatedly. Re-runs stop+replace the container
# so fixes to flags or image pins propagate.

set -euo pipefail

CADDY_IMAGE="${CADDY_IMAGE:-caddy:2.8}"
CADDY_NETWORK="${CADDY_NETWORK:-voodu0}"
STATE_DIR="${VOODU_CADDY_STATE_DIR:-/opt/voodu/caddy}"
DATA_DIR="$STATE_DIR/data"
CONFIG_DIR="$STATE_DIR/config"
CONTAINER_NAME="${VOODU_CADDY_CONTAINER:-voodu-caddy}"

PLUGIN_DIR="${VOODU_PLUGIN_DIR:-$(cd "$(dirname "$0")" && pwd)}"
PLUGIN_BIN="$PLUGIN_DIR/bin/voodu-caddy"
RELEASE_REPO="${VOODU_CADDY_RELEASE_REPO:-thadeu/voodu-caddy}"

log() { printf '[voodu-caddy/install] %s\n' "$*"; }

arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) echo "unsupported arch: $(uname -m)" >&2; exit 1 ;;
  esac
}

install_voodu_caddy() {
  local version
  version="$(grep '^version:' "$PLUGIN_DIR/plugin.yml" | awk '{print $2}')"

  if [ -z "$version" ]; then
    log "could not read version from $PLUGIN_DIR/plugin.yml" >&2
    exit 1
  fi

  if [ -x "$PLUGIN_BIN" ] && "$PLUGIN_BIN" --version 2>/dev/null | grep -q "$version"; then
    log "voodu-caddy v$version already installed at $PLUGIN_BIN"
    return
  fi

  local a
  a="$(arch)"

  local url="https://github.com/${RELEASE_REPO}/releases/download/v${version}/voodu-caddy_linux_${a}"

  log "downloading voodu-caddy v$version ($a) from $url"

  mkdir -p "$(dirname "$PLUGIN_BIN")"

  local tmp
  tmp="$(mktemp)"

  if ! curl -fsSL "$url" -o "$tmp"; then
    rm -f "$tmp"
    log "failed to download voodu-caddy binary from $url" >&2
    log "make sure release v$version was published with the linux_${a} asset" >&2
    exit 1
  fi

  install -m 0755 "$tmp" "$PLUGIN_BIN"
  rm -f "$tmp"

  log "installed $PLUGIN_BIN"
}

# Apps share voodu0 with Caddy so Caddy can resolve upstream container
# names. clowk-voodu's install creates this network as part of the
# server bootstrap; we defensively (re)create it here for standalone
# plugin installs onto servers provisioned by older clowk-voodu versions.
ensure_network() {
  if docker network inspect "$CADDY_NETWORK" >/dev/null 2>&1; then
    log "docker network $CADDY_NETWORK already exists"
    return
  fi

  log "creating docker network $CADDY_NETWORK"
  docker network create --driver bridge "$CADDY_NETWORK" >/dev/null
}

seed_state() {
  mkdir -p "$DATA_DIR" "$CONFIG_DIR" "$STATE_DIR/routes"

  # Bootstrap config consumed on first container start. `--resume` then
  # replays whatever the plugin has POSTed to /load, so this file is
  # only loaded on a fresh machine.
  #
  # Admin API listens on 0.0.0.0:2019 inside the container so docker's
  # port-mapping (-p 127.0.0.1:2019:2019) can reach it. The host-side
  # bind is localhost-only — operators get the same security posture as
  # the old systemd setup where Admin API was bound to 127.0.0.1.
  local empty_json="$CONFIG_DIR/empty.json"

  if [ ! -f "$empty_json" ]; then
    cat >"$empty_json" <<'JSON'
{
  "admin": { "listen": "0.0.0.0:2019" },
  "apps": { "http": { "servers": {} } }
}
JSON
  fi
}

pull_image() {
  # Pull once per install so the `docker run` step below doesn't block
  # on an implicit pull (which would dump progress into stderr and
  # interleave with our log lines). Explicit pull is also what surfaces
  # a registry error cleanly instead of masking it as a run failure.
  log "pulling $CADDY_IMAGE"
  docker pull --quiet "$CADDY_IMAGE" >/dev/null
}

run_container() {
  # Stop+remove any pre-existing container so flag changes (new ports,
  # new mounts, new image pin) propagate. The state dirs are on the
  # host via bind mounts, so routes/certs survive the replace.
  if docker ps -a --format '{{.Names}}' | grep -qx "$CONTAINER_NAME"; then
    log "removing existing $CONTAINER_NAME container"
    docker rm -f "$CONTAINER_NAME" >/dev/null
  fi

  log "starting $CONTAINER_NAME on $CADDY_NETWORK"

  # --restart=unless-stopped replaces the systemd unit: docker daemon
  # restores the container at boot, survives crashes, honors `docker stop`.
  #
  # Port mappings:
  #   :80, :443   → public ingress (bind-all so requests from any iface reach Caddy)
  #   127.0.0.1:2019 → Admin API (localhost-only — same as old systemd posture)
  docker run -d \
    --name "$CONTAINER_NAME" \
    --network "$CADDY_NETWORK" \
    --restart unless-stopped \
    -p 80:80 \
    -p 443:443 \
    -p 443:443/udp \
    -p 127.0.0.1:2019:2019 \
    -v "$DATA_DIR:/data" \
    -v "$CONFIG_DIR:/config" \
    "$CADDY_IMAGE" \
    caddy run --config /config/empty.json --resume >/dev/null

  # Give Caddy a beat to bind Admin API before declaring success so that
  # a plugin call right after install doesn't race the container.
  local i=0
  while [ $i -lt 15 ]; do
    if curl -fsS --max-time 1 http://127.0.0.1:2019/config/ >/dev/null 2>&1; then
      log "$CONTAINER_NAME ready (admin at 127.0.0.1:2019)"
      return
    fi

    i=$((i + 1))
    sleep 1
  done

  log "warning: $CONTAINER_NAME did not respond on 127.0.0.1:2019 within 15s"
  log "inspect with: docker logs $CONTAINER_NAME"
}

main() {
  if [ "$(id -u)" -ne 0 ]; then
    log "this script must run as root (invoked by controller via plugins:install)"
    exit 1
  fi

  if ! command -v docker >/dev/null 2>&1; then
    log "docker is required but not found on PATH" >&2
    exit 1
  fi

  install_voodu_caddy
  ensure_network
  seed_state
  pull_image
  run_container
}

main "$@"
