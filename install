#!/usr/bin/env bash
# install — lifecycle hook run by `voodu plugins:install caddy`.
#
# Responsibilities:
#   1. Download the voodu-caddy plugin binary into $VOODU_PLUGIN_DIR/bin/voodu-caddy
#   2. Download the Caddy binary into /opt/voodu/caddy/bin/caddy
#   3. Write the systemd unit that launches Caddy with Admin API on :2019
#   4. Enable and start the unit
#   5. Seed an empty routes/ directory so reload works on fresh install
#
# Idempotent: safe to run repeatedly. Skips steps whose outputs already
# exist with the right version.

set -euo pipefail

CADDY_VERSION="${CADDY_VERSION:-2.8.4}"
STATE_DIR="${VOODU_CADDY_STATE_DIR:-/opt/voodu/caddy}"
BIN_DIR="$STATE_DIR/bin"
CADDY_BIN="$BIN_DIR/caddy"
UNIT_PATH="/etc/systemd/system/voodu-caddy.service"

PLUGIN_DIR="${VOODU_PLUGIN_DIR:-$(cd "$(dirname "$0")" && pwd)}"
PLUGIN_BIN="$PLUGIN_DIR/bin/voodu-caddy"
RELEASE_REPO="${VOODU_CADDY_RELEASE_REPO:-thadeu/voodu-caddy}"

log() { printf '[voodu-caddy/install] %s\n' "$*"; }

arch() {
  case "$(uname -m)" in
    x86_64|amd64) echo "amd64" ;;
    aarch64|arm64) echo "arm64" ;;
    *) echo "unsupported arch: $(uname -m)" >&2; exit 1 ;;
  esac
}

install_voodu_caddy() {
  local version
  version="$(grep '^version:' "$PLUGIN_DIR/plugin.yml" | awk '{print $2}')"

  if [ -z "$version" ]; then
    log "could not read version from $PLUGIN_DIR/plugin.yml" >&2
    exit 1
  fi

  if [ -x "$PLUGIN_BIN" ] && "$PLUGIN_BIN" --version 2>/dev/null | grep -q "$version"; then
    log "voodu-caddy v$version already installed at $PLUGIN_BIN"
    return
  fi

  local a
  a="$(arch)"

  local url="https://github.com/${RELEASE_REPO}/releases/download/v${version}/voodu-caddy_linux_${a}"

  log "downloading voodu-caddy v$version ($a) from $url"

  mkdir -p "$(dirname "$PLUGIN_BIN")"

  local tmp
  tmp="$(mktemp)"

  if ! curl -fsSL "$url" -o "$tmp"; then
    rm -f "$tmp"
    log "failed to download voodu-caddy binary from $url" >&2
    log "make sure release v$version was published with the linux_${a} asset" >&2
    exit 1
  fi

  install -m 0755 "$tmp" "$PLUGIN_BIN"
  rm -f "$tmp"

  log "installed $PLUGIN_BIN"
}

install_caddy() {
  if [ -x "$CADDY_BIN" ] && "$CADDY_BIN" version 2>/dev/null | grep -q "v$CADDY_VERSION"; then
    log "caddy v$CADDY_VERSION already installed"
    return
  fi

  local a
  a="$(arch)"

  local url="https://github.com/caddyserver/caddy/releases/download/v${CADDY_VERSION}/caddy_${CADDY_VERSION}_linux_${a}.tar.gz"

  log "downloading caddy v$CADDY_VERSION ($a)"

  mkdir -p "$BIN_DIR"

  local tmp
  tmp="$(mktemp -d)"

  trap 'rm -rf "$tmp"' EXIT

  curl -fsSL "$url" -o "$tmp/caddy.tar.gz"

  tar -xzf "$tmp/caddy.tar.gz" -C "$tmp" caddy

  install -m 0755 "$tmp/caddy" "$CADDY_BIN"

  log "installed $CADDY_BIN"
}

write_unit() {
  # Rewrite on every install: this is how fixes to the generated unit
  # (bad flags, new env vars) reach existing servers. Operators with
  # local tweaks should use a systemd drop-in at
  # /etc/systemd/system/voodu-caddy.service.d/override.conf instead —
  # drop-ins survive a rewrite, edits to this file do not.
  log "writing $UNIT_PATH"

  cat >"$UNIT_PATH" <<UNIT
[Unit]
Description=Voodu Caddy (ingress)
Documentation=https://github.com/thadeu/voodu-caddy
After=network-online.target
Wants=network-online.target

[Service]
Type=notify
Environment=XDG_DATA_HOME=$STATE_DIR/data
Environment=XDG_CONFIG_HOME=$STATE_DIR/config
ExecStart=$CADDY_BIN run --config $STATE_DIR/empty.json --resume
ExecReload=$CADDY_BIN reload --config $STATE_DIR/empty.json --force
Restart=on-failure
RestartSec=5s
LimitNOFILE=1048576
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
UNIT

  systemctl daemon-reload
}

seed_state() {
  mkdir -p "$STATE_DIR/routes"

  # A minimal bootstrap config. --resume then replays whatever the
  # plugin has POSTed to /load, so this only runs on a fresh machine.
  if [ ! -f "$STATE_DIR/empty.json" ]; then
    cat >"$STATE_DIR/empty.json" <<'JSON'
{
  "admin": { "listen": "127.0.0.1:2019" },
  "apps": { "http": { "servers": {} } }
}
JSON
  fi
}

enable_unit() {
  systemctl enable voodu-caddy.service
  systemctl restart voodu-caddy.service
  log "voodu-caddy running (admin at 127.0.0.1:2019)"
}

main() {
  if [ "$(id -u)" -ne 0 ]; then
    log "this script must run as root (invoked by controller via plugins:install)"
    exit 1
  fi

  install_voodu_caddy
  install_caddy
  seed_state
  write_unit
  enable_unit
}

main "$@"
